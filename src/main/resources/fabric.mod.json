{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Keeps Minecraft from interrupting music when switching worlds/servers or returning to the title screen.",
  "authors": [
    "DarkAndBlue"
  ],
  "contact": {
    "sources": "https://github.com/DarkAndBlue/KeepThatMusic"
  },
  "license": "CC0-1.0",
  "icon": "assets/keepthatmusic/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "de.darkandblue.keepthatmusic.KeepThatMusic"
    ],
    "modmenu": [
      "de.darkandblue.keepthatmusic.modmenu.ModMenuIntegration"
    ]
  },
  "mixins": [
    "keepthatmusic.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16",
    "minecraft": "${minecraft}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
